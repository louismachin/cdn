<!DOCTYPE html>
<html>
<%= erb :_head, locals: { copy: @copy } %>
<body>
    <div id="page">
        <div class="toolbar">
            <div class="toolbar-left">
                <% unless read_only %>
                    <button class="btn btn-ghost" onclick="window.location = '/login'">Login</button>
                <% else %>
                    <button class="btn btn-ghost" onclick="window.location = '/logout'">Logout</button>
                <% end %>
                <span class="wordmark"><!-- <%= @copy[:title] %> --></span>
                <%= erb :_breadcrumb, locals: { key: @key } rescue '' %>
            </div>
            <div class="buttons">
                <% unless read_only %>
                    <button class="btn btn-secondary" onclick="showNewFolder()">New Folder</button>
                    <button class="btn btn-primary" onclick="showUpload()">&#8593; Upload</button>
                <% end %>
            </div>
        </div>

        <div class="file-table-wrap">
            <%= erb :_images, locals: { file_tree: @file_tree, key: @key, is_jailed: @is_jailed } %>
        </div>

        <%= erb :_modal_base %>
        <%= erb :_file_info_modal, locals: { key: @key } %>
        <%= erb :_upload_modal, locals: { key: @key } %>
        <%= erb :_new_folder_modal, locals: { key: @key } %>
        <%= erb :_move_modal, locals: { key: @key, all_dirs: @all_dirs } %>
    </div>
</body>
</html>
