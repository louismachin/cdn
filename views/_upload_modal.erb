<div id="upload-pop-up" class="pop-up">
    <div class="pop-up-header">Upload Files</div>
    <div class="pop-up-body">
        <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
            <span class="drop-icon">&#8686;</span>
            <p>Drop files here or click to browse</p>
        </div>
        <ul class="selected-file-list" id="selectedFileList"></ul>
        <input type="file" id="fileInput" name="file" multiple style="display:none">
    </div>
    <div class="pop-up-footer">
        <div id="upload-status" class="status"></div>
        <div class="buttons">
            <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
            <button class="btn btn-primary" id="uploadBtn" onclick="doUpload()" disabled>Upload</button>
        </div>
    </div>
</div>

<script>
const dropZone        = document.getElementById('dropZone')
const fileInput        = document.getElementById('fileInput')
const uploadBtn        = document.getElementById('uploadBtn')
const selectedFileList = document.getElementById('selectedFileList')
let chosenFiles = []

function showUpload() {
    chosenFiles = []
    fileInput.value = ''
    selectedFileList.innerHTML = ''
    uploadBtn.disabled = true
    openModal('upload-pop-up')
}

fileInput.addEventListener('change', () => { chosenFiles = chosenFiles.concat(Array.from(fileInput.files)); fileInput.value = ''; showSelected() })
dropZone.addEventListener('dragover', (e) => { e.preventDefault(); dropZone.classList.add('dragover') })
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'))
dropZone.addEventListener('drop', (e) => {
    e.preventDefault()
    dropZone.classList.remove('dragover')
    chosenFiles = chosenFiles.concat(Array.from(e.dataTransfer.files))
    showSelected()
})

function formatSize(bytes) {
    if (bytes < 1024) return bytes + ' B'
    if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB'
    return (bytes / (1024 * 1024)).toFixed(1) + ' MB'
}

function iconFor(filename) {
    const ext = filename.split('.').pop().toLowerCase()
    if (['jpg', 'jpeg', 'png', 'gif', 'webp', 'heic', 'svg'].includes(ext)) return '\u{1F5BC}\u{FE0F}'
    if (['mp4', 'mov', 'avi', 'webm'].includes(ext)) return '\u{1F3AC}'
    if (['mp3', 'wav', 'flac'].includes(ext)) return '\u{1F3B5}'
    if (['pdf'].includes(ext)) return '\u{1F4C4}'
    if (['zip', 'tar', 'gz'].includes(ext)) return '\u{1F5C3}\u{FE0F}'
    return '\u{1F4C4}'
}

function removeFile(index) {
    chosenFiles.splice(index, 1)
    showSelected()
}

function showSelected() {
    uploadBtn.disabled = !chosenFiles.length

    if (!chosenFiles.length) {
        selectedFileList.innerHTML = ''
        return
    }

    const items = chosenFiles.map((f, ix) => `
        <li class="selected-file-item">
            <span class="selected-file-icon">${iconFor(f.name)}</span>
            <span class="selected-file-name">${f.name}</span>
            <span class="selected-file-size">${formatSize(f.size)}</span>
            <button class="selected-file-remove" onclick="removeFile(${ix})" title="Remove">&times;</button>
        </li>`).join('')

    const totalSize = chosenFiles.reduce((sum, f) => sum + f.size, 0)
    const summary = `<li class="selected-file-summary">${chosenFiles.length} file${chosenFiles.length === 1 ? '' : 's'} &middot; ${formatSize(totalSize)} total</li>`

    selectedFileList.innerHTML = summary + items
}

async function doUpload() {
    if (!chosenFiles.length) return
    uploadBtn.disabled = true

    let successCount = 0
    let failures = []

    for (const file of chosenFiles) {
        uploadBtn.textContent = `Uploading ${successCount + failures.length + 1} of ${chosenFiles.length}…`
        try {
            const formData = new FormData()
            formData.append('file', file)
            const res = await fetch('/upload/<%= key.join('/') %>', { method: 'POST', body: formData })
            const data = await res.json()
            if (data.success) successCount++
            else failures.push(file.name)
        } catch (err) {
            failures.push(file.name)
        }
    }

    if (failures.length === 0) {
        window.location.reload()
    } else {
        const s = document.getElementById('upload-status')
        s.textContent = `${successCount} uploaded, ${failures.length} failed`
        s.className = 'status error'
        uploadBtn.disabled = false
        uploadBtn.textContent = 'Upload'
    }
}
</script>

<style>
.selected-file-list {
  list-style: none;
  max-height: 240px;
  overflow-y: auto;
  margin-top: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.selected-file-list:empty {
  display: none;
}

.selected-file-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  font-size: 13px;
}

.selected-file-icon {
  font-size: 16px;
  flex-shrink: 0;
  width: 20px;
  text-align: center;
}

.selected-file-name {
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  color: var(--text);
}

.selected-file-size {
  font-size: 11px;
  color: var(--text-muted);
  flex-shrink: 0;
}

.selected-file-remove {
  background: none;
  border: none;
  cursor: pointer;
  color: var(--text-muted);
  font-size: 14px;
  padding: 2px 4px;
  border-radius: 4px;
  line-height: 1;
  flex-shrink: 0;
}
.selected-file-remove:hover {
  color: var(--danger);
  background: #fce8e6;
}

.selected-file-summary {
  padding: 8px 10px;
  font-size: 12px;
  color: var(--text-muted);
  text-align: center;
}
</style>