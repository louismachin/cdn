<div id="info-pop-up" class="pop-up">
    <div class="pop-up-header">Properties</div>
    <div class="pop-up-body">
        <div id="popup-content"></div>
    </div>
    <div class="pop-up-footer">
        <div id="status" class="status"></div>
        <div class="buttons">
            <button class="btn btn-ghost" onclick="closeModal()">Cancel</button>
            <button class="btn btn-primary" onclick="saveInfo()">Save</button>
        </div>
    </div>
</div>

<script>
    let currentUri = ''
    let data = {}

    let showInfo = (uri) => {
        currentUri = uri
        document.getElementById('popup-content').innerHTML = '<p style="color:#5f6368;font-size:13px">Loading…</p>'
        openModal('info-pop-up')
        fetch(uri)
            .then(r => r.json())
            .then(result => { data = { ...result }; renderTable() })
            .catch(() => { document.getElementById('popup-content').innerHTML = '<p style="color:#d93025;font-size:13px">Error loading data.</p>' })
    }

    let renderTable = () => {
        let rows = ''
        for (let key in data) {
            rows += `
                <tr>
                    <td><input type="text" value="${key}" onchange="updateKey('${key}', this.value)"></td>
                    <td><input type="text" value="${data[key]}" onchange="updateValue('${key}', this.value)"></td>
                    <td><button class="remove-btn" onclick="removeRow('${key}')">×</button></td>
                </tr>`
        }
        rows += `
            <tr>
                <td><input type="text" id="newKey" placeholder="key"></td>
                <td><input type="text" id="newValue" placeholder="value"></td>
                <td><button class="add-btn" onclick="addRow()">+</button></td>
            </tr>`

        document.getElementById('popup-content').innerHTML = `
            <table class="kv-table">
                <thead>
                    <tr><th>Key</th><th>Value</th><th></th></tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>`
    }

    let updateKey = (oldKey, newKey) => {
        if (newKey && newKey !== oldKey) {
            data[newKey] = data[oldKey]
            delete data[oldKey]
            renderTable()
        }
    }

    let updateValue = (key, value) => { data[key] = value }
    let removeRow   = (key) => { delete data[key]; renderTable() }

    let addRow = () => {
        const key   = document.getElementById('newKey').value
        const value = document.getElementById('newValue').value
        if (key) { data[key] = value; renderTable() }
    }

    let saveInfo = () => {
        fetch(currentUri, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        })
        .then(() => {
            const s = document.getElementById('status')
            s.textContent = 'Saved'
            s.className = 'status success'
            setTimeout(() => { s.className = 'status'; s.textContent = '' }, 2000)
        })
        .catch(() => {
            const s = document.getElementById('status')
            s.textContent = 'Error saving'
            s.className = 'status error'
        })
    }
</script>
