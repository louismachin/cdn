<!DOCTYPE html>
<html>
<%= erb :_head, locals: { copy: @copy } %>
<% base_uri = '/upload' %>
<% base_uri += '/' + key.join('/') if key && !key.empty? %>
<body>
    <div id="page">
        <div class="toolbar">
            <div class="toolbar-left">
                <span class="wordmark"><%= @copy[:title] %></span>
            </div>
            <div class="buttons">
                <button class="btn btn-ghost" onclick="history.back()">&#8592; Back</button>
            </div>
        </div>

        <div class="upload-wrap">
            <div class="drop-zone" id="dropZone" onclick="document.getElementById('fileInput').click()">
                <span class="drop-icon">&#8686;</span>
                <p>Drop files here or click to browse</p>
                <small>Uploads to /<%= key.join('/') %></small>
            </div>
            <ul class="selected-file-list" id="selectedFileList"></ul>
            <input type="file" id="fileInput" name="file" multiple>
            <button class="btn btn-primary" id="uploadBtn" onclick="doUpload()" disabled>Upload</button>
        </div>
    </div>
</body>

<script>
    const dropZone      = document.getElementById('dropZone')
    const fileInput      = document.getElementById('fileInput')
    const uploadBtn      = document.getElementById('uploadBtn')
    const selectedFileList = document.getElementById('selectedFileList')
    let chosenFiles = []

    fileInput.addEventListener('change', () => {
        chosenFiles = Array.from(fileInput.files)
        showSelected()
    })

    dropZone.addEventListener('dragover', (e) => {
        e.preventDefault()
        dropZone.classList.add('dragover')
    })
    dropZone.addEventListener('dragleave', () => dropZone.classList.remove('dragover'))
    dropZone.addEventListener('drop', (e) => {
        e.preventDefault()
        dropZone.classList.remove('dragover')
        chosenFiles = Array.from(e.dataTransfer.files)
        showSelected()
    })

    function showSelected() {
        if (!chosenFiles.length) return
        selectedFileList.innerHTML = chosenFiles.map(f => `<li>${f.name}</li>`).join('')
        uploadBtn.disabled = false
    }

    async function doUpload() {
        if (!chosenFiles.length) return
        uploadBtn.disabled = true

        let successCount = 0
        let failures = []

        for (const file of chosenFiles) {
            uploadBtn.textContent = `Uploading ${successCount + failures.length + 1} of ${chosenFiles.length}…`
            try {
                const formData = new FormData()
                formData.append('file', file)
                const res = await fetch('<%= base_uri %>', { method: 'POST', body: formData })
                const ct = res.headers.get('content-type')
                const data = ct && ct.includes('application/json')
                    ? await res.json()
                    : (() => { throw new Error('Unexpected response') })()
                if (data.success) successCount++
                else failures.push(file.name)
            } catch (err) {
                failures.push(file.name)
            }
        }

        if (failures.length === 0) {
            window.location.href = '/'
        } else {
            alert(`${successCount} uploaded, ${failures.length} failed: ${failures.join(', ')}`)
            resetBtn()
        }
    }

    function resetBtn() {
        uploadBtn.disabled = false
        uploadBtn.textContent = 'Upload'
    }
</script>
</html>
