<!DOCTYPE html>
<html>
<%= erb :_head, locals: { copy: @copy } %>
<% base_uri = '/new_folder' %>
<% base_uri += '/' + key.join('/') if key && !key.empty? %>
<body>
    <div id="page">
        <div class="toolbar">
            <div class="toolbar-left">
                <span class="wordmark"><%= @copy[:title] %></span>
            </div>
            <div class="buttons">
                <button class="btn btn-ghost" onclick="history.back()">&#8592; Back</button>
            </div>
        </div>
        <div class="upload-wrap">
            <p>Create a new folder in /<%= key.join('/') %></p>
            <input type="text" id="folderName" placeholder="Folder name" autofocus>
            <button class="btn btn-primary" id="createBtn" onclick="doCreate()">Create</button>
        </div>
    </div>
</body>
<script>
const folderName = document.getElementById('folderName')
const createBtn  = document.getElementById('createBtn')

folderName.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') doCreate()
})

function doCreate() {
    const name = folderName.value.trim()
    if (!name) return
    createBtn.disabled = true
    createBtn.textContent = 'Creating…'

    fetch('<%= base_uri %>', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: 'name=' + encodeURIComponent(name)
    })
        .then(r => r.json())
        .then(data => {
            if (data.success) window.location.href = '/'
            else { alert('Failed: ' + (data.error || 'unknown error')); resetBtn() }
        })
        .catch(err => { alert('Failed: ' + err.message); resetBtn() })
}

function resetBtn() {
    createBtn.disabled = false
    createBtn.textContent = 'Create'
}
</script>
</html>